# === DJANGO ===
SECRET_KEY=СГЕНЕРИРУЕТСЯ_АВТОМАТИЧЕСКИ_ПРИ_ДЕПЛОЕ
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1

# === DATABASE (локальный PostgreSQL) ===
DATABASE_URL=postgresql://edubest_user:ПАРОЛЬ@localhost:5432/edubest

# === REDIS (локальный) ===
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# === JWT ===
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# === EMAIL ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=EDU BEST <no-reply@yourdomain.com>

# === SMS ===
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# === CORS ===
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# === ПЛАТЕЖИ ===
PLATFORM_COMMISSION_PERCENT=20

# === БЭКАП ===
DAILY_BACKUP_PATH=/var/backups/edubest
